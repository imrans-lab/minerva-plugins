(footprint "PAD_FIELDS" (layer "F.Cu")
  (pad "1" smd roundrect (at -1 0 90) (size 1.2 1.0) (layers "F.Cu" "F.Paste" "F.Mask")
    (roundrect_rratio 0.25)
    (solder_mask_margin 0.05)
    (solder_paste_margin -0.02))
  (pad "2" thru_hole oval (at 1 0) (size 1.6 2.0) (drill oval 0.9 1.4) (layers "*.Cu" "*.Mask"))
  (pad "3" smd rect (at 3 0) (size 1.0 1.0) (layers "F.Cu"))
  (fp_line (start -2 -1) (end 2 -1) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
)
