{
  "id": "codetools",
  "name": "Code Tools",
  "version": "0.1.0",
  "host_api_version": "1",
  "release_targets": ["linux-x86_64", "macos-universal", "windows-x86_64"],
  "backend": {
    "transport": "stdio",
    "entrypoint": "./codetools-plugin",
    "args": []
  },
  "tools": [],
  "ui": {
    "ipc_messages": [
      "minerva_codetools_get_graph"
    ],
    "panels": [
      {
        "name": "code_graph",
        "kind": "godot_scene",
        "entry_scene": "ui/code_graph/CodeGraphPanel.tscn",
        "scripts": [
          "ui/code_graph/code_graph_panel.gd",
          "ui/code_graph/code_graph_view.gd",
          "ui/code_graph/graph_data.gd",
          "ui/code_graph/annotation_data.gd",
          "ui/code_graph/level1_boundary_view.gd",
          "ui/code_graph/level2_component_view.gd",
          "ui/code_graph/level3_symbol_view.gd"
        ],
        "ipc_channels": [
          "minerva_codetools_get_graph"
        ],
        "save_mode": "none"
      }
    ]
  },
  "editor_items": [
    {
      "id": "open_code_graph",
      "name": "Code Graph",
      "panel": "code_graph",
      "default_filename": "code_visualizer.db"
    }
  ],
  "permissions": {
    "host_capabilities": [],
    "network": {
      "mode": "none"
    },
    "filesystem": {
      "mode": "none",
      "paths": []
    }
  },
  "data_directory": "",
  "autostart": false,
  "auto_reload": false
}
