# Built Go binaries — build from source per FCIB policy (embedded bundle makes
# these 25-40MB; never commit them).
build/
codetools-plugin
codetools-plugin.exe
*.testbin
*.testbin.exe

# PBS runtime build scratch (download cache + extraction stage). The final
# embedded bundle under internal/runtime/bundle/ is git-ignored separately
# (see internal/runtime/bundle/.gitignore).
runtime-build/

# Dev/test code-graph SQLite store. The code_graph panel resolves its DB to
# the plugin source dir for an in-place install, so a locally-indexed
# code_visualizer.db (+ WAL sidecars) lands here during HITL/dev. Never commit
# it — it's regenerated by indexing a codebase. See docket hint 019e8edf.
code_visualizer.db
code_visualizer.db-shm
code_visualizer.db-wal
code_visualizer.db-journal
