# Built Go binaries — build from source per FCIB policy.
# Match every plugin's binary regardless of name pattern.
*/cad-plugin
*/cad-plugin.exe
*/cad-plugin-*
*/presentation-plugin
*/presentation-plugin.exe
*/presentation-plugin-*
*/pcb-plugin
*/pcb-plugin.exe
*/pcb-plugin-*
# Presentation plugin's Go binary is named just "presentation" inside its own dir.
presentation/presentation
# Scansort plugin's Rust binary.
scansort/scansort-plugin
scansort/scansort-plugin.exe
# Agent-relay plugin's Rust binary.
agent-relay/agent-relay-plugin
agent-relay/agent-relay-plugin.exe
# Rust build artifacts (target/ dirs).
agent-relay/target/
# Generic catch for plugin binaries built at the plugin root.
# Add new patterns here as additional plugins land.

# Runtime build artifacts (PBS Python tarballs etc.)
*/runtime-build/*.tar.zst
*/runtime-build/*.tar.gz
*/runtime-build/*.zip

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
.venv/
venv/
env/

# IDE / OS
.DS_Store
*.swp
*.swo
.idea/
.vscode/

# Godot import cache (not authoritative; regenerated on open)
.godot/

# Docket SQLite working layer (regenerated from the committed .dct; never commit)
*.dct.cache
*.dct.cache-shm
*.dct.cache-wal
